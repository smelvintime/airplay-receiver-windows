<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AirPlayReceiver.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AirPlayReceiver"
    Title="AirPlay Receiver">

    <Grid x:Name="RootGrid" Background="#FF1A1A1A">
        <!-- Custom title bar (drag region) -->
        <Grid
            x:Name="TitleBarGrid"
            Height="32"
            VerticalAlignment="Top"
            Background="Transparent" />

        <!--
            VideoPresenter: the SwapChainPanel that hosts the D3D11 swap chain.
            Margins are set in code-behind to letterbox while preserving aspect ratio.
        -->
        <SwapChainPanel
            x:Name="VideoSurface"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            DoubleTapped="VideoPresenter_DoubleTapped" />

        <!-- Idle / waiting overlay — hidden once a stream arrives -->
        <StackPanel
            x:Name="IdleOverlay"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12">
            <Image
                Source="Assets/AirPlayIcon.png"
                Width="80"
                Height="80"
                Opacity="0.6" />
            <TextBlock
                x:Name="DeviceNameText"
                HorizontalAlignment="Center"
                FontSize="22"
                FontWeight="SemiBold"
                Foreground="#FFEEEEEE"
                Text="AirPlay Receiver" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="14"
                Foreground="#FF888888"
                Text="Open Control Center on your iPhone and tap Screen Mirroring" />
        </StackPanel>

        <!-- Stream info HUD (bottom-left, shown during active session) -->
        <Border
            x:Name="InfoHud"
            Margin="12,0,0,12"
            Padding="8,4"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="#AA000000"
            CornerRadius="4"
            Visibility="Collapsed">
            <TextBlock
                x:Name="InfoText"
                FontFamily="Consolas"
                FontSize="11"
                Foreground="#FFAAAAAA" />
        </Border>
    </Grid>
</Window>
